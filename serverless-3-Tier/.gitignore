# Local .terraform directory (contains providers and modules)
.terraform/

# .tfstate files (Contains sensitive infrastructure data)
# These should be stored in a GCS Backend, not version control
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (Likely contain secrets/project-specific IDs)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# --- GCP Specifics ---

# Service Account Key files (JSON)
# Highly sensitive! Never commit these.
*.json
# If you use a specific naming convention for keys, use that instead:
# credentials.json
# gcp-key.json
